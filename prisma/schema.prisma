// AnzuIngestion — Prisma schema
// Default: SQLite for local dev. Switch provider to "postgresql" for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  invoices       Invoice[]
  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model Invoice {
  id           String           @id @default(uuid())
  referenceNo  String           @unique
  channel      String           // web | email | whatsapp
  status       String           @default("received") // received | processing | extracted | reviewed | complete | error
  fileUrl      String           // local path or S3 URL
  fileName     String
  mimeType     String
  fileSize     Int?
  submittedBy  String?          // email address or phone number
  submittedName String?         // provider name if given
  submittedAt  DateTime         @default(now())
  processedAt  DateTime?
  reviewedBy   String?
  flags        String           @default("[]")  // JSON array of flag strings
  isDuplicate  Boolean          @default(false)
  duplicateOf  String?          // references another invoice id
  ocrText      String?          // cleaned OCR text — stored for few-shot learning & fine-tuning
  vendorId     String?
  vendor       Vendor?          @relation(fields: [vendorId], references: [id])
  extractedData  ExtractedField[]
  lineItems      LineItem[]
  events         IngestionEvent[]
  corrections    CorrectionLog[]
  invoiceMatches InvoiceMatch[]

  @@map("invoices")
}

model CorrectionLog {
  id             String   @id @default(uuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  fieldName      String
  originalValue  String?  // what the AI extracted
  correctedValue String?  // what the admin set it to
  correctedBy    String?
  correctedAt    DateTime @default(now())

  @@map("correction_logs")
}

model ExtractedField {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  fieldName   String
  value       String?
  confidence  Float?
  isVerified  Boolean @default(false)
  isUncertain Boolean @default(false)

  @@map("extracted_data")
}

model LineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String?
  quantity    Float?
  unitPrice   Float?
  lineTotal   Float?
  category    String? // material | labor | equipment | freight | overhead | tax | discount | other
  confidence  Float?

  @@map("line_items")
}

model IngestionEvent {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  eventType String   // received | processing_started | extracted | extraction_failed | reviewed | flagged | exported
  timestamp DateTime @default(now())
  metadata  String?  // JSON string

  @@map("ingestion_events")
}

// Application-wide key-value settings (editable from the admin Settings page)
model Setting {
  key       String   @id   // e.g. "default_currency", "default_country"
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── Project / PO Matching Module ─────────────────────────────────────────────

model Project {
  id             String          @id @default(uuid())
  name           String
  code           String?         @unique
  address        String?
  city           String?
  vat            String?         // Tax/NIT number
  supervisor     String?         // Person responsible for the project
  budget         Float?
  currency       String          @default("COP")
  status         String          @default("active") // active | closed | on_hold
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
  invoiceMatches InvoiceMatch[]

  @@map("projects")
}

model PurchaseOrder {
  id             String         @id @default(uuid())
  poNumber       String         @unique
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id])
  vendorId       String?
  vendor         Vendor?        @relation(fields: [vendorId], references: [id])
  vendorName     String?        // denormalized for fast display
  vendorTaxId    String?        // NIT / tax ID of vendor
  description    String?
  totalAmount    Float?
  currency       String         @default("COP")
  issueDate      DateTime?
  expiryDate     DateTime?
  status         String         @default("open") // open | partially_matched | fully_matched | closed
  source         String         @default("manual") // manual | ocr | erp
  fileUrl        String?        // stored PO document
  ocrText        String?        // cleaned OCR text for audit
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  invoiceMatches InvoiceMatch[]

  @@map("purchase_orders")
}

model CajaChica {
  id             String         @id @default(uuid())
  name           String
  period         String?        // e.g. "Q1-2025"
  balance        Float?
  currency       String         @default("COP")
  status         String         @default("open") // open | closed
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  invoiceMatches InvoiceMatch[]

  @@map("caja_chica")
}

model InvoiceMatch {
  id              String         @id @default(uuid())
  invoiceId       String
  invoice         Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  matchType       String         // "project" | "purchase_order" | "caja_chica"
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  cajaChicaId     String?
  cajaChica       CajaChica?     @relation(fields: [cajaChicaId], references: [id])
  confidence      Float?
  reasoning       String?
  matchedBy       String?        // "ai" | admin username
  matchedAt       DateTime       @default(now())
  isConfirmed     Boolean        @default(false)
  confirmedBy     String?
  confirmedAt     DateTime?

  @@map("invoice_matches")
}
