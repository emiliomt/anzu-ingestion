# ──────────────────────────────────────────────────────
# AnzuIngestion — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
# Local dev (SQLite — zero setup):
DATABASE_URL="file:./dev.db"
# Production PostgreSQL (Railway / Supabase / Neon):
# DATABASE_URL="postgresql://user:password@host:5432/anzuingestion?sslmode=require"

# ── Authentication (Auth.js / NextAuth) ───────────
# Required — generate with: openssl rand -base64 32
AUTH_SECRET=""
# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: <APP_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Admin credentials login (fallback / no Google OAuth required) ─────────
# Set both to enable email + password sign-in at /login
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# ── AI Extraction ─────────────────────────────────────
# Required — get from https://platform.openai.com
OPENAI_API_KEY=""

# ── App URL ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── File Storage ──────────────────────────────────────
# "local" for dev/Railway with persistent volume
# "s3"    for Vercel or cloud (requires AWS vars below)
STORAGE_TYPE="local"
STORAGE_PATH="./uploads"

# AWS S3 (required when STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""

# ── Email (SMTP) ──────────────────────────────────────
# Leave blank to skip (logs to console). Mailtrap for dev, SendGrid/SES for prod.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AnzuIngestion <noreply@anzuingestion.com>"

# SendGrid Inbound Parse webhook secret (for email ingestion)
SENDGRID_WEBHOOK_SECRET=""

# ── WhatsApp / Twilio ─────────────────────────────────
# Leave blank to disable WhatsApp channel
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Docker / Railway ──────────────────────────────────
# Set to "standalone" in Dockerfile ENV (already set)
# NEXT_OUTPUT="standalone"
