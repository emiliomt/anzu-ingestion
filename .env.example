# ──────────────────────────────────────────────────────
# AnzuIngestion — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
# Local dev (SQLite — zero setup):
DATABASE_URL="file:./dev.db"
# Production PostgreSQL (Railway / Supabase / Neon):
# DATABASE_URL="postgresql://user:password@host:5432/anzuingestion?sslmode=require"

# ── Authentication (Clerk) ────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Sign-in/up redirect URLs (must match Clerk dashboard settings)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin

# ── AI Extraction ─────────────────────────────────────
# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ── App URL ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── File Storage ──────────────────────────────────────
# "local" for dev/Railway with persistent volume
# "s3"    for Vercel or cloud (requires AWS vars below)
STORAGE_TYPE="local"
STORAGE_PATH="./uploads"

# AWS S3 (required when STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""

# ── Email (SMTP) ──────────────────────────────────────
# Leave blank to skip (logs to console). Mailtrap for dev, SendGrid/SES for prod.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AnzuIngestion <noreply@anzuingestion.com>"

# SendGrid Inbound Parse webhook secret (for email ingestion)
SENDGRID_WEBHOOK_SECRET=""

# ── WhatsApp / Twilio ─────────────────────────────────
# Leave blank to disable WhatsApp channel
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Docker / Railway ──────────────────────────────────
# Set to "standalone" in Dockerfile ENV (already set)
# NEXT_OUTPUT="standalone"
