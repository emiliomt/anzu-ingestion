# ──────────────────────────────────────────────────────────────────────────────
# Anzu Dynamics — Environment Variables
# Automates invoice lifecycle: OCR → AI validation → ERP submission → VAT recovery
# Target markets: Mexico (CFDI) and Colombia (Factura Electrónica)
# Copy this file to .env and fill in your values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite — zero setup):
# DATABASE_URL="file:./dev.db"
# Production PostgreSQL (Railway / Supabase / Neon / docker-compose):
DATABASE_URL="postgresql://anzu:anzupassword@localhost:5432/anzuingestion"

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
# Enable Organizations in Clerk dashboard for multi-tenancy.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Sign-in/up redirect URLs (must match Clerk dashboard settings)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard/onboarding

# ── AI Extraction ─────────────────────────────────────────────────────────────
# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=""
# Optional — for GPT-4o OCR fallback
OPENAI_API_KEY=""

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://app.anzudynamics.com"

# ── File Storage ──────────────────────────────────────────────────────────────
# "local" for dev/Railway with persistent volume
# "s3"    for Vercel or cloud (requires AWS vars below)
STORAGE_TYPE="local"
STORAGE_PATH="./uploads"

# AWS S3 (required when STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""

# ── Credential Vault (ERP passwords) ─────────────────────────────────────────
# AES-256-GCM key — MUST be exactly 64 hex chars (32 bytes).
# Generate with: openssl rand -hex 32
# KEEP THIS SECRET. Rotate if compromised.
VAULT_KEY=""

# ── Redis (BullMQ background jobs) ───────────────────────────────────────────
# Local dev: redis://localhost:6379
# docker-compose: redis://redis:6379
# Railway / Upstash: rediss://...
REDIS_URL="redis://localhost:6379"

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Test mode keys from https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Demo Sessions (shareable no-login 30-min preview links) ──────────────────
# Generate with: openssl rand -hex 32
DEMO_JWT_SECRET=""
DEMO_SESSION_TTL_MINUTES="30"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank to skip (logs to console). Mailtrap for dev, SendGrid/SES for prod.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Anzu Dynamics <noreply@anzudynamics.com>"

# SendGrid Inbound Parse webhook secret (for email ingestion)
SENDGRID_WEBHOOK_SECRET=""

# ── WhatsApp / Twilio ─────────────────────────────────────────────────────────
# Leave blank to disable WhatsApp ingestion channel
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Security Microservice (anzu-security) ────────────────────────────────────
# Optional: SAT Art.69-B EFOS blacklist checker for Mexican invoices.
# Leave blank to skip all security checks.
SECURITY_SERVICE_URL=""
# Example: SECURITY_SERVICE_URL="https://anzu-security.railway.app"
SECURITY_API_KEY=""
SECURITY_ORG_ID="default"

# ── Docker / Railway ──────────────────────────────────────────────────────────
# Set to "standalone" in Dockerfile ENV (already set)
# NEXT_OUTPUT="standalone"
