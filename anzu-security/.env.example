# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, Railway volume path):
DATABASE_URL=sqlite:////data/anzu_security.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:pass@host:5432/anzu_security

# ── Downstream matcher ─────────────────────────────────────────────────────────
MATCHER_URL=https://your-anzu-matcher.railway.app/api/v1/ingest
MATCHER_API_KEY=

# ── Security for this service's own API ───────────────────────────────────────
# Leave empty to disable auth (only do this behind a private network)
API_KEY=

# ── SAT blacklist ──────────────────────────────────────────────────────────────
SAT_REFRESH_INTERVAL_HOURS=24
SAT_DOWNLOAD_TIMEOUT_SECONDS=60

# ── Matching thresholds (0–100) ────────────────────────────────────────────────
NAME_MATCH_THRESHOLD=85.0
ADDRESS_MATCH_THRESHOLD=80.0
SAT_NAME_MATCH_THRESHOLD=85.0

# ── Logging ───────────────────────────────────────────────────────────────────
DEBUG=false
